# ==========================================
# SERVER ENVIRONMENT VARIABLES
# Place these in: server/.env
# ==========================================

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/authsystem?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
CLIENT_URL=http://localhost:5173

# Admin Seeder (Auto-creates this admin user on startup)
ADMIN_EMAIL=admin@authsystem.com
ADMIN_PASSWORD=SecureAdmin123!

# SMTP Configuration (For Email Verification & Password Reset)
# If using Gmail, you MUST use an App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_16_digit_app_password
FROM_NAME=AuthSystem
FROM_EMAIL=your_email@gmail.com


# ==========================================
# CLIENT ENVIRONMENT VARIABLES
# Place these in: client/.env
# ==========================================

VITE_API_URL=http://localhost:5000/api

# Google OAuth 2.0 Client ID
# Get this from Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
